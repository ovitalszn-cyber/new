# KashRock API
NEXT_PUBLIC_API_BASE_URL=https://backend.kashrock.com

# Landing maintenance overlay (set true to block the homepage)
# NEXT_PUBLIC_MAINTENANCE_MODE=true
# NEXT_PUBLIC_MAINTENANCE_MESSAGE=We're making a few upgrades. The site will be back shortly.

# Google OAuth
# Get your Google Client ID from Google Cloud Console > Credentials > OAuth 2.0 Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
