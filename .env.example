# KashRock API
API_BASE_URL=http://localhost:8000
APP_URL=http://localhost:3000

# Landing maintenance overlay (set true to block the homepage)
# NEXT_PUBLIC_MAINTENANCE_MODE=true
# NEXT_PUBLIC_MAINTENANCE_MESSAGE=Expanding coverage — Call of Duty and Rainbow Six Siege are coming online. We'll be back shortly.

# Google OAuth
# Register APP_URL/api/auth/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
