# Railway Environment Variables Template
# Copy this file and fill in your actual values

# ============================================================================
# CORE CONFIGURATION
# ============================================================================
PORT=8000
HOST=0.0.0.0
WORKERS=2
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# HISTORICAL DATABASE (Railway Volume)
# ============================================================================
# Path to the volume-mounted historical database
# This should match your Railway volume mount path
HISTORICAL_DB_PATH=/data/kashrock_historical.db

# ============================================================================
# DATABASE URLS
# ============================================================================
# PostgreSQL database for auth and control plane
# Railway will automatically provide this as DATABASE_URL
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/kashrock

# Redis for caching
# Get this from Railway Redis addon or external Redis provider
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# API KEYS & EXTERNAL SERVICES
# ============================================================================
# The Odds API key
ODDS_API_KEY=your_odds_api_key_here

# ESPN API key (if needed)
ESPN_API_KEY=your_espn_api_key_here

# ============================================================================
# SECURITY
# ============================================================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_minimum_32_characters

# Admin secret for admin endpoints
ADMIN_SECRET=your_admin_secret_here

# Google OAuth Client ID for dashboard authentication
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_BETTING_FEATURES=true
ENABLE_METRICS=true

# ============================================================================
# MONITORING
# ============================================================================
METRICS_PORT=9090

# ============================================================================
# RATE LIMITING
# ============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# STREAMING CONFIGURATION
# ============================================================================
STREAM_BATCH_SIZE=100
STREAM_INTERVAL=1.0
MAX_CONNECTIONS=1000

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with real values to git
# 2. Use Railway's environment variable UI or CLI to set these
# 3. Generate strong random values for SECRET_KEY and ADMIN_SECRET
# 4. The HISTORICAL_DB_PATH should match your volume mount path
# 5. Railway automatically provides DATABASE_URL for PostgreSQL
